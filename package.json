{
  "name": "dynamic-island-content-app",
  "version": "0.1.0",
  "private": true,
  "description": "macOS-first dynamic island content overlay",
  "type": "module",
  "main": "out/main/main.js",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "electron-vite dev -- -- -ApplePersistenceIgnoreState YES",
    "dev:native": "AGENT_ISLAND_USE_NATIVE_HOST=1 electron-vite dev -- -- -ApplePersistenceIgnoreState YES",
    "dev:browser-host": "AGENT_ISLAND_USE_BROWSER_HOST=1 electron-vite dev -- -- -ApplePersistenceIgnoreState YES",
    "build": "electron-vite build",
    "dist:mac": "pnpm native:build && pnpm build && electron-builder --mac dmg",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "native:build": "node-gyp rebuild --directory native/macos-overlay-panel"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.2.4",
    "lucide-react": "^1.8.0",
    "node-addon-api": "^8.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "node-gyp": "^11.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.3.2",
    "vitest": "^3.1.2"
  },
  "build": {
    "appId": "com.sai.agent-dynamic-island",
    "productName": "Agent Dynamic Island",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "out/renderer/**/*",
      "out/main/native/**/*.node"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
